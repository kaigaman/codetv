APP_NAME=CODETV
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Docker: DB_HOST=mysql / Local: DB_HOST=127.0.0.1
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=codetv
DB_USERNAME=codetv
DB_PASSWORD=codetv_pass

# Docker: REDIS_HOST=redis / Local: not needed for file/sync queue
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Docker: PYTHON_API=http://python:8000 / Local: http://127.0.0.1:8000
PYTHON_API=http://127.0.0.1:8000

IPTV_ORG_API=https://iptv-org.github.io/api/channels.json
IPTV_ORG_STREAMS=https://iptv-org.github.io/api/streams.json
FREE_TV_M3U=https://raw.githubusercontent.com/Free-TV/IPTV/master/playlist.m3u8
UGANDA_M3U=https://iptv-org.github.io/iptv/countries/ug.m3u

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,localhost:3000
SESSION_DOMAIN=localhost
